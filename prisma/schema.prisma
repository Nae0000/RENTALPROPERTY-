generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoomStatus {
  VACANT
  OCCUPIED
  MAINTENANCE
}

enum LeaseStatus {
  ACTIVE
  EXPIRED
  TERMINATED
}

enum InvoiceStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum ExpenseType {
  FIXED
  WATER
  ELECTRICITY
  REPAIR
  OTHER
}

enum DocumentType {
  LEASE_AGREEMENT
  ID_CARD
  OTHER
}

enum CalendarEventType {
  RENT_DUE
  LEASE_EXPIRY
  PAYMENT_RECEIVED
  MAINTENANCE
}

enum SyncStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
}

model Property {
  id          String    @id @default(cuid())
  name        String
  address     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  rooms       Room[]
  snapshots   ReportSnapshot[]
}

model Room {
  id                String           @id @default(cuid())
  propertyId        String
  roomNumber        String
  status            RoomStatus       @default(VACANT)
  monthlyRent       Decimal          @db.Decimal(10, 2)
  currentTenantName String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?
  property          Property         @relation(fields: [propertyId], references: [id])
  leases            LeaseContract[]
  invoices          RentInvoice[]
  expenses          ExpenseRecord[]
  utilityReadings   UtilityReading[]
  calendarEvents    CalendarEvent[]

  @@unique([propertyId, roomNumber])
  @@index([propertyId, status])
}

model Tenant {
  id          String           @id @default(cuid())
  fullName    String
  phone       String
  profileData Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  leases      LeaseContract[]
  documents   TenantDocument[]
  invoices    RentInvoice[]

  @@index([fullName])
  @@index([phone])
}

model LeaseContract {
  id             String          @id @default(cuid())
  roomId         String
  tenantId       String
  startDate      DateTime
  endDate        DateTime
  monthlyRent    Decimal         @db.Decimal(10, 2)
  securityAmount Decimal         @db.Decimal(10, 2)
  status         LeaseStatus     @default(ACTIVE)
  terms          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  room           Room            @relation(fields: [roomId], references: [id])
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  documents      TenantDocument[]
  deposits       DepositLedger[]

  @@index([roomId, status])
  @@index([tenantId, status])
}

model TenantDocument {
  id              String         @id @default(cuid())
  tenantId        String?
  leaseContractId String?
  type            DocumentType
  fileName        String
  fileUrl         String
  mimeType        String
  fileSize        Int
  createdAt       DateTime       @default(now())
  tenant          Tenant?        @relation(fields: [tenantId], references: [id])
  leaseContract   LeaseContract? @relation(fields: [leaseContractId], references: [id])

  @@index([tenantId, type])
  @@index([leaseContractId, type])
}

model RentInvoice {
  id             String               @id @default(cuid())
  roomId         String
  tenantId       String
  billingYear    Int
  billingMonth   Int
  dueDate        DateTime
  amount         Decimal              @db.Decimal(10, 2)
  status         InvoiceStatus        @default(PENDING)
  paidAt         DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  room           Room                 @relation(fields: [roomId], references: [id])
  tenant         Tenant               @relation(fields: [tenantId], references: [id])
  payments       PaymentTransaction[]

  @@unique([roomId, billingYear, billingMonth])
  @@index([dueDate, status])
  @@index([tenantId, status])
}

model PaymentTransaction {
  id             String      @id @default(cuid())
  rentInvoiceId  String
  paidAmount     Decimal     @db.Decimal(10, 2)
  paidAt         DateTime
  method         String
  referenceNo    String?
  note           String?
  createdAt      DateTime    @default(now())
  rentInvoice    RentInvoice @relation(fields: [rentInvoiceId], references: [id])

  @@index([paidAt])
}

model DepositLedger {
  id              String        @id @default(cuid())
  leaseContractId String
  amount          Decimal       @db.Decimal(10, 2)
  type            String
  effectiveDate   DateTime
  note            String?
  createdAt       DateTime      @default(now())
  leaseContract   LeaseContract @relation(fields: [leaseContractId], references: [id])

  @@index([leaseContractId, effectiveDate])
}

model ExpenseRecord {
  id          String      @id @default(cuid())
  roomId      String?
  type        ExpenseType
  title       String
  amount      Decimal     @db.Decimal(10, 2)
  expenseDate DateTime
  note        String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  room        Room?       @relation(fields: [roomId], references: [id])

  @@index([type, expenseDate])
  @@index([roomId, expenseDate])
}

model UtilityReading {
  id             String   @id @default(cuid())
  roomId         String
  readingDate    DateTime
  meterType      String
  usageAmount    Decimal  @db.Decimal(10, 2)
  chargeAmount   Decimal  @db.Decimal(10, 2)
  sourceProvider String?
  createdAt      DateTime @default(now())
  room           Room     @relation(fields: [roomId], references: [id])

  @@index([roomId, readingDate])
}

model CalendarEvent {
  id          String            @id @default(cuid())
  roomId      String?
  title       String
  eventType   CalendarEventType
  eventDate   DateTime
  status      String
  metadata    Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  room        Room?             @relation(fields: [roomId], references: [id])

  @@index([eventDate, eventType])
}

model ReportSnapshot {
  id            String    @id @default(cuid())
  propertyId    String
  year          Int
  month         Int
  totalIncome   Decimal   @db.Decimal(12, 2)
  totalExpense  Decimal   @db.Decimal(12, 2)
  occupancyRate Decimal   @db.Decimal(5, 2)
  payload       Json
  createdAt     DateTime  @default(now())
  property      Property  @relation(fields: [propertyId], references: [id])
  syncJobs      SyncJob[]

  @@unique([propertyId, year, month])
}

model SyncJob {
  id               String       @id @default(cuid())
  reportSnapshotId String
  provider         String
  status           SyncStatus   @default(QUEUED)
  startedAt        DateTime?
  finishedAt       DateTime?
  errorMessage     String?
  createdAt        DateTime     @default(now())
  reportSnapshot   ReportSnapshot @relation(fields: [reportSnapshotId], references: [id])

  @@index([status, createdAt])
}
